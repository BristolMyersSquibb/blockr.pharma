linters: linters_with_defaults(
    object_name_linter = NULL,        # matches blockr.dm
    object_usage_linter = NULL,       # matches blockr.dplyr / blockr.viz
    object_length_linter = NULL,      # matches blockr.dm
    line_length_linter = NULL,        # matches blockr.dplyr / blockr.viz
    commented_code_linter = NULL,     # matches blockr.dplyr / blockr.viz
    indentation_linter = NULL,        # matches blockr.dplyr / blockr.viz
    brace_linter = NULL,               # matches blockr.dm / blockr.ggplot
    quotes_linter = NULL               # HTML/SVG string fragments built via
                                        # paste0(); mixed single/double quoting
                                        # throughout is deliberate (avoids
                                        # escaping the embedded HTML attrs)
  )
